# Django core
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=jobdekho.jobexhibition.com,jobexhibition.com,www.jobexhibition.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://jobdekho.jobexhibition.com,https://jobexhibition.com,https://www.jobexhibition.com

# Proxy / SSL
DJANGO_TRUST_X_FORWARDED_PROTO=True
DJANGO_USE_X_FORWARDED_HOST=True
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True

# Optional HSTS
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False

# Static cache-busting version
STATIC_ASSET_VERSION=2
DJANGO_STATICFILES_STORAGE=whitenoise.storage.CompressedManifestStaticFilesStorage

# Database (Hostinger MySQL)
DB_ENGINE=django.db.backends.mysql
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=srv685.hstgr.io
DB_PORT=3306
DB_CONN_MAX_AGE=60
DB_CONNECT_TIMEOUT=20

# Optional SSL CA path for MySQL
# DB_SSL_CA=/path/to/ca.pem

# Email (SMTP) for OTP / notifications
# Based on PHP SMTP credentials (smtpcodesphp.md)
# Hostinger SMTP Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_HOST_USER=registration@sabkapaisa.com
EMAIL_HOST_PASSWORD=Admin$12345
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True
DEFAULT_FROM_EMAIL=SabkaPaisa <registration@sabkapaisa.com>
SITE_TITLE=SabkaPaisa

# OTP / SMS (Fast2SMS)
OTP_SMS_PROVIDER=fast2sms
# Required: set a real Fast2SMS API key (placeholders are treated as empty).
OTP_SMS_API_KEY=replace-with-fast2sms-api-key
# Optional aliases (app reads first non-empty among OTP_SMS_API_KEY, OTP_FAST2SMS_API_KEY, FAST2SMS_API_KEY)
# OTP_FAST2SMS_API_KEY=
# FAST2SMS_API_KEY=
OTP_SMS_API_URL=https://www.fast2sms.com/dev/bulkV2
OTP_FAST2SMS_ROUTE=dlt
OTP_FAST2SMS_SENDER_ID=GBJOB
OTP_FAST2SMS_MESSAGE_ID=211271
OTP_FAST2SMS_ENTITY_ID=
OTP_FAST2SMS_TEMPLATE_ID=
OTP_FAST2SMS_VARIABLES_VALUES=
OTP_FAST2SMS_REGISTER_MESSAGE_ID=211271
OTP_FAST2SMS_FORGOT_PASSWORD_MESSAGE_ID=211269
OTP_FAST2SMS_ACCOUNT_DELETE_MESSAGE_ID=211270
OTP_FAST2SMS_LOGIN_MESSAGE_ID=211271
OTP_FAST2SMS_REGISTER_VARIABLES_VALUES=
OTP_FAST2SMS_FORGOT_PASSWORD_VARIABLES_VALUES=||
OTP_FAST2SMS_ACCOUNT_DELETE_VARIABLES_VALUES=||
OTP_FAST2SMS_LOGIN_VARIABLES_VALUES=
OTP_SMS_TIMEOUT_SECONDS=10
OTP_DEBUG_SHOW_IN_MESSAGES=False
OTP_ALLOW_DEBUG_FALLBACK=False
OTP_ALLOW_CONSOLE_EMAIL=False
