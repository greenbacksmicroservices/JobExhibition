# Django core
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=jobdekho.jobexhibition.com,jobexhibition.com,www.jobexhibition.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://jobdekho.jobexhibition.com,https://jobexhibition.com,https://www.jobexhibition.com

# Proxy / SSL
DJANGO_TRUST_X_FORWARDED_PROTO=True
DJANGO_USE_X_FORWARDED_HOST=True
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True

# Optional HSTS
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False

# Static cache-busting version
STATIC_ASSET_VERSION=2
DJANGO_STATICFILES_STORAGE=whitenoise.storage.CompressedManifestStaticFilesStorage

# Database (Hostinger MySQL)
DB_ENGINE=django.db.backends.mysql
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=srv685.hstgr.io
DB_PORT=3306
DB_CONN_MAX_AGE=60
DB_CONNECT_TIMEOUT=20

# Optional SSL CA path for MySQL
# DB_SSL_CA=/path/to/ca.pem

# Email (SMTP) for OTP / notifications
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_primary_sender@gmail.com
EMAIL_HOST_PASSWORD=your-primary-app-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=JobExhibition <your_primary_sender@gmail.com>
SITE_TITLE=JobExhibition

# Optional fallback sender account (used if primary SMTP fails)
EMAIL_FALLBACK_HOST=smtp.gmail.com
EMAIL_FALLBACK_PORT=587
EMAIL_FALLBACK_HOST_USER=your_fallback_sender@gmail.com
EMAIL_FALLBACK_HOST_PASSWORD=your-fallback-app-password
EMAIL_FALLBACK_USE_TLS=True
EMAIL_FALLBACK_USE_SSL=False
EMAIL_FALLBACK_FROM_EMAIL=JobExhibition <your_fallback_sender@gmail.com>

# OTP / SMS (Fast2SMS)
OTP_SMS_PROVIDER=fast2sms
# Required: set a real Fast2SMS API key (placeholders are treated as empty).
OTP_SMS_API_KEY=replace-with-fast2sms-api-key
# Optional aliases (app reads first non-empty among OTP_SMS_API_KEY, OTP_FAST2SMS_API_KEY, FAST2SMS_API_KEY)
# OTP_FAST2SMS_API_KEY=
# FAST2SMS_API_KEY=
OTP_SMS_API_URL=https://www.fast2sms.com/dev/bulkV2
OTP_FAST2SMS_ROUTE=dlt
OTP_FAST2SMS_SENDER_ID=GBJOB
OTP_FAST2SMS_MESSAGE_ID=211271
OTP_FAST2SMS_ENTITY_ID=
OTP_FAST2SMS_TEMPLATE_ID=
OTP_FAST2SMS_VARIABLES_VALUES=
OTP_FAST2SMS_REGISTER_MESSAGE_ID=211271
OTP_FAST2SMS_FORGOT_PASSWORD_MESSAGE_ID=211269
OTP_FAST2SMS_ACCOUNT_DELETE_MESSAGE_ID=211270
OTP_FAST2SMS_LOGIN_MESSAGE_ID=211271
OTP_FAST2SMS_REGISTER_VARIABLES_VALUES=
OTP_FAST2SMS_FORGOT_PASSWORD_VARIABLES_VALUES=||
OTP_FAST2SMS_ACCOUNT_DELETE_VARIABLES_VALUES=||
OTP_FAST2SMS_LOGIN_VARIABLES_VALUES=
OTP_SMS_TIMEOUT_SECONDS=10
OTP_DEBUG_SHOW_IN_MESSAGES=False
OTP_ALLOW_DEBUG_FALLBACK=False
OTP_ALLOW_CONSOLE_EMAIL=False

# Subscription payment gateway
PORT=3000
NODE_ENV=development
PAYMENT_GATEWAY_PROVIDER=PhonePe
PAYMENT_GATEWAY_INITIATE_URL=http://localhost:3000/api/payment/initiate
PAYMENT_GATEWAY_STATUS_URL=http://localhost:3000/api/payment/status
PAYMENT_GATEWAY_CALLBACK_SECRET=replace-with-callback-secret
PAYMENT_GATEWAY_TIMEOUT_SECONDS=20
PAYMENT_GATEWAY_DEMO_AUTO_SUCCESS=False
PAYMENT_GATEWAY_INTERNAL_FALLBACK=False

# Dedicated payment database mirror (second database)
PAYMENT_DB_ENABLED=True
PAYMENT_DB_ALIAS=payment
PAYMENT_DB_ENGINE=django.db.backends.mysql
PAYMENT_DB_NAME=your_payment_db_name
PAYMENT_DB_USER=your_payment_db_user
PAYMENT_DB_PASSWORD=your_payment_db_password
PAYMENT_DB_HOST=srv685.hstgr.io
PAYMENT_DB_PORT=3306
PAYMENT_DB_CONN_MAX_AGE=60
PAYMENT_DB_CONNECT_TIMEOUT=20
PAYMENT_DB_READ_TIMEOUT=30
PAYMENT_DB_WRITE_TIMEOUT=30
# PAYMENT_DB_SSL_CA=/path/to/ca.pem

# PhonePe / merchant passthrough (v2)
PHONEPE_BASE_URL=https://api.phonepe.com/apis/pg
PHONEPE_OAUTH_BASE_URL=https://api.phonepe.com/apis/identity-manager
PHONEPE_PAY_PATH=/checkout/v2/pay
PHONEPE_STATUS_PATH=/checkout/v2/order/{merchant_transaction_id}/status
MERCHANT_ID=replace-with-merchant-id
SALT_KEY=replace-with-salt-key
SALT_INDEX=1
PHONEPE_CLIENT_ID=replace-with-phonepe-client-id
PHONEPE_CLIENT_SECRET=replace-with-phonepe-client-secret
PHONEPE_CLIENT_VERSION=1
PHONEPE_ENV=PRODUCTION
MERCHANT_REDIRECT_URL=https://your-domain.com/payment/redirect
MERCHANT_CALLBACK_URL=https://your-domain.com/api/payment/callback
MERCHANT_USERNAME=replace-with-merchant-username
MERCHANT_PASSWORD=replace-with-merchant-password

# QR payment rendering on checkout page
PAYMENT_QR_UPI_ID=merchant@upi
PAYMENT_QR_PAYEE_NAME=Job Exhibition
PAYMENT_QR_NOTE_PREFIX=Subscription
